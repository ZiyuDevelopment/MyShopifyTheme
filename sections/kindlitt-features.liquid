<section class="kindlitt-section kindlitt-light">
  <div class="kindlitt-container">

    <div style="text-align:center;margin-bottom:70px;">
      <h2 class="kindlitt-heading-lg">
        Archived for Generations
      </h2>

      <p class="kindlitt-muted" style="
        max-width:700px;
        margin:20px auto 0;
        line-height:1.8;
      ">
        We believe technology should serve the human spirit,
        not distract it.
      </p>
    </div>

    <div class="kindlitt-grid" style="
      grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    ">

      <div class="kindlitt-card">
        <h3 class="kindlitt-heading-md">
          Shared Achievements
        </h3>

        <p class="kindlitt-muted" style="margin-top:20px;line-height:1.8;">
          Every page turned is a family milestone.
        </p>
      </div>

      <div class="kindlitt-card">
        <h3 class="kindlitt-heading-md">
          Pure Focus
        </h3>

        <p class="kindlitt-muted" style="margin-top:20px;line-height:1.8;">
          A typography-first interface free from distraction.
        </p>
      </div>

      <div class="kindlitt-card">
        <h3 class="kindlitt-heading-md">
          Family Sanctuary
        </h3>

        <p class="kindlitt-muted" style="margin-top:20px;line-height:1.8;">
          Unified reading paths for intentional families.
        </p>
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "KindLitt Features",
  "presets": [
    {
      "name": "KindLitt Features"
    }
  ]
}
{% endschema %}