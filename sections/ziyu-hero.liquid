<section class="min-h-screen flex flex-col justify-center items-center relative px-6 overflow-hidden bg-[#f8f9ff] text-[#0d1c2f]">

  <div class="absolute inset-0 opacity-10 pointer-events-none">

    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-orange-300 rounded-full blur-[120px]"></div>

    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-yellow-200 rounded-full blur-[120px]"></div>

  </div>

  <div class="max-w-4xl text-center relative z-10">

    <span class="uppercase tracking-[0.2em] text-gray-500 mb-6 block text-sm">
      The Archival Scroll
    </span>

    <h1 class="text-5xl md:text-[84px] leading-tight mb-8 font-serif">

      Software to help you

      <span class="italic text-[#8d4b00] font-normal">
        catch your breath.
      </span>

    </h1>

    <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-12">

      Ziyu is a laboratory for digital and physical artifacts that prioritize stillness.

    </p>

    <a
      class="inline-flex items-center gap-3 text-[#8d4b00]"
      href="#digital"
    >

      Explore the Ecosystem

      <span class="material-symbols-outlined">
        east
      </span>

    </a>

  </div>

</section>

