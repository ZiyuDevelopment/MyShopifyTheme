<section
  id="philosophy"
  class="py-[180px] bg-[#233144] text-[#ebf1ff]"
>

  <div class="max-w-4xl mx-auto px-6 text-center">

    <h2 class="text-4xl md:text-6xl leading-tight font-serif mb-12">

      “We believe the most powerful technology
      is the one that knows when to disappear.”

    </h2>

    <div class="w-24 h-px bg-[#8d4b00] mx-auto mb-12"></div>

    <p class="text-xl leading-relaxed opacity-80 max-w-3xl mx-auto mb-20">

      Our philosophy is rooted in Enlightened Stillness.
      We reject dopamine-driven design patterns in favor of
      clarity, longevity, and human dignity.

    </p>

    <div class="grid md:grid-cols-3 gap-12 text-left">

      <div>

        <h3 class="uppercase tracking-[0.2em] text-sm text-[#ffb77d] mb-4">

          Anti-Viral

        </h3>

        <p class="opacity-70 leading-relaxed">

          We build software that solves problems rather than
          seeking attention. No feeds. No streaks. No hooks.

        </p>

      </div>

      <div>

        <h3 class="uppercase tracking-[0.2em] text-sm text-[#ffb77d] mb-4">

          Generational

        </h3>

        <p class="opacity-70 leading-relaxed">

          Artifacts designed to last decades, not quarters.
          Open standards and physical durability.

        </p>

      </div>

      <div>

        <h3 class="uppercase tracking-[0.2em] text-sm text-[#ffb77d] mb-4">

          Human-Centric

        </h3>

        <p class="opacity-70 leading-relaxed">

          Prioritizing biological needs over growth metrics
          and addictive engagement patterns.

        </p>

      </div>

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Ziyu Philosophy",
  "settings": []
}
{% endschema %}